generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Vecindario {
  vecindarioId Int       @id @default(autoincrement())
  nombre       String
  localidadId  Int
  Localidad    Localidad  @relation(fields: [localidadId], references: [localidadId])
  ubicacion    String
  usuarios     Usuario[] // Relación con usuarios
}

model Provincia {
  provinciaId  Int        @id @default(autoincrement())
  nombre       String
  localidades  Localidad[] // Relación con localidades
}

model Localidad {
  localidadId  Int        @id @default(autoincrement())
  nombre       String
  provinciaId  Int
  Provincia    Provincia  @relation(fields: [provinciaId], references: [provinciaId])
  vecindarios  Vecindario[] // Relación con vecindarios
}

model Notificacion {
  notificacionId Int       @id @default(autoincrement())
  titulo         String
  notificacion   String
  contenido      String
  tipo           String
  fechaHora      DateTime  @default(now())
  usuarioId      Int
  usuario        Usuario   @relation(fields: [usuarioId], references: [usuarioId])
}

model Usuario {
  usuarioId      Int             @id @default(autoincrement())
  nombre         String
  apellido       String
  email          String          @unique
  contrasena     String
  telefono       String
  direccion      String
  vecindarioId   Int
  vecindario     Vecindario      @relation(fields: [vecindarioId], references: [vecindarioId])
  notificaciones Notificacion[]  // Relación con notificaciones
  alarmas        Alarma[]        // Relación con alarmas
}

model Alarma {
  alarmaId       Int       @id @default(autoincrement())
  descripcion    String
  activo         Boolean   @default(true)
  fechaHora      DateTime  @default(now())
  tipo           String
  usuarioId      Int
  usuario        Usuario   @relation(fields: [usuarioId], references: [usuarioId])
}
